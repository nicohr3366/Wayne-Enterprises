# (pueden ser grandes y cada quien los genera localmente)

apps/*/data/*.xlsx
apps/*/data/*.xls
apps/*/data/*.json
apps/*/data/*.xml

# Excepción: mantener la carpeta data/ vacía con .gitkeep
!apps/*/data/.gitkeep

